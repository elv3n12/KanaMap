    "d3-interpolate": "^3.0.1",
    "d3-selection": "^3.0.0",
    "deck.gl": "^9.3.2",
    "maplibre-gl": "^5.24.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
