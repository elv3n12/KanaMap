APP_DOMAIN=example.org
APP_URL=https://example.org
NEXTAUTH_URL=https://example.org
APP_NAME_FR="Observatoire Européen des NéoCannabinoïdes"
APP_TAGLINE_FR="Cartographier la déferlante"
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true

DATABASE_URL=mysql://kanamap:kanamap_password@mysql:3306/kanamap
MYSQL_DATABASE=kanamap
MYSQL_USER=kanamap
MYSQL_PASSWORD=kanamap_password
MYSQL_ROOT_PASSWORD=replace-with-root-password

IP_HASH_SALT=replace-with-a-long-random-salt
TOKEN_HASH_SECRET=replace-with-a-long-random-secret

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@example.org
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="Cannabinoid Observatory Europe <contact@example.org>"
ADMIN_EMAIL=admin@example.org

SEED_ADMIN_EMAIL=admin@example.org
SEED_ADMIN_PASSWORD=replace-with-admin-password
SEED_MODERATOR_EMAIL=moderateur@example.org
SHOW_FIXTURE_BADGE=true

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
